{
  "build": {
    "env": {
      "GO_VERSION": "1.21"
    }
  },
  "functions": {
    "app/**/*.go": {
      "runtime": "@vercel/go@1.21.0"
    }
  },
  "builds": [
    {
      "src": "main.go",
      "use": "@vercel/go",
      "config": {
        "goVersion": "1.21"
      }
    },
    {
      "src": "web/air/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/main"
    },
    {
      "src": "/(.*)",
      "dest": "/web/air/build/$1"
    }
  ]
}
